# Claude Code Plugin - .gitignore

# Runtime State (Claude Code manages this)
.claude/
.agent-state/

# Logs
*.log
logs/

# Test Results (generated by tests)
test-results/
playwright-report/
.playwright/

# Coverage
coverage/
.nyc_output/

# Environment
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*.sublime-*

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Generated Test Artifacts (by the plugin)
test-designs/
pages/
tests/functional/
tests/integration/
tests/api/
tests/e2e/
!tests/.gitkeep

# Backup files (created by LocatorHealingAgent)
*.bak
*.backup
*.page.js.bak

# Temporary files
*.tmp
*.temp
tmp/
temp/

# Deprecated JavaScript implementation (keep directory, ignore contents if needed)
deprecated/node_modules/
deprecated/package-lock.json
